---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import QuoteTicker from '../components/QuoteTicker.astro';
import signatures from '../data/signatures.yaml';
import { logoPath } from '../lib/signatures';
import { languages } from '../i18n/config';
import { getLandingStrings, getTranslationPercent } from '../i18n/locales';
import { markdownify } from '../i18n/config';
import LanguagePicker from '../components/LanguagePicker.astro';

// Build a JSON map of supported locale codes → paths for the redirect script
const localePaths = Object.fromEntries(
  Object.entries(languages)
    .filter(([code]) => code !== 'en')
    .map(([code, { path }]) => [code.toLowerCase(), path])
);
import '../styles/landing.css';
import techPressQuotes from '../data/quotes/tech-press.yaml';
import editorialQuotes from '../data/quotes/editorials.yaml';
import orgQuotes from '../data/quotes/organizations.yaml';
import creatorQuotes from '../data/quotes/creators.yaml';
import communityQuotes from '../data/quotes/community.yaml';
import changeOrgQuotes from '../data/quotes/changeorg.yaml';

const locale = 'en';
const t = getLandingStrings(locale);
const translatePct = getTranslationPercent(locale);
const translateUrl = `https://github.com/keepandroidopen/keepandroidopen.github.io/tree/main/src/i18n/locales/${locale}.yaml`;

// Fisher-Yates shuffle for build-time randomization
function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const pressItems = shuffle(techPressQuotes);
const editorialItems = shuffle(editorialQuotes);
const orgItems = shuffle(orgQuotes);
const creatorItems = shuffle(creatorQuotes);
const communityItems = shuffle(communityQuotes);

const filteredPetitionQuotes = (changeOrgQuotes as any[]).filter(q => q.lang === locale && !q.flag);
const petitionItems = shuffle(filteredPetitionQuotes).slice(0, 100);

const shuffledSigs = shuffle(signatures as any[]);
const sigCountryCount = new Set(signatures.map((s: any) => s.region).filter(Boolean)).size;

// countdown
const deadline = new Date('2026-09-01T00:00:00Z');
const now = new Date();
const daysLeft = Math.max(0, Math.ceil((deadline.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
---
<Base title={t.title} lang={locale} description={t.description}>
  <script set:html={`
/**
 * @license magnet:?xt=urn:btih:8e4f440f4c65981c5bf93c76d35135ba5064d8b7&dn=apache-2.0.txt Apache-2.0
 * Keep Android Open – Browser Language Redirect
 * Copyright 2025-2026 Keep Android Open Contributors
 * SPDX-License-Identifier: Apache-2.0
 */
(function() {
  var paths = ${JSON.stringify(localePaths)};

  // Try to match a browser language against our supported locales.
  // Returns the path for the first match, or null.
  function matchLang(tag) {
    if (!tag) return null;
    var t = tag.toLowerCase();
    // Exact match (e.g. "pt-br" -> "pt-BR")
    if (paths[t]) return paths[t];
    // Prefix match (e.g. "fr-fr" -> "fr", "zh-hans" -> "zh-cn")
    var prefix = t.split('-')[0];
    for (var code in paths) {
      if (code === prefix || code.split('-')[0] === prefix) {
        return paths[code];
      }
    }
    return null;
  }

  // Walk the full navigator.languages preference list (Firefox, Chrome, Safari).
  // Fall back to navigator.language for browsers that don't support the array.
  var langs = navigator.languages || [navigator.language || ''];
  var dest = null;
  for (var i = 0; i < langs.length; i++) {
    dest = matchLang(langs[i]);
    if (dest) break;
    // If the first preferred language is English, stop: user wants English.
    if (i === 0 && langs[i].toLowerCase().split('-')[0] === 'en') break;
  }

  if (dest) window.location.replace(dest);
})();
// @license-end
`} />
  <nav class="topbar">
    <ThemeToggle />
    <LanguagePicker locale={locale} />
  </nav>

  <main>
    <!-- Hero -->
    <section id="top" class="hero">
      <p class="hero-lede">
        <Fragment set:html={t.hero_lede} />
      </p>
      <div class="countdown-strip">
        <span class="countdown-number">{daysLeft}</span>
        <span class="countdown-label">{t.hero_countdown_label}</span>
      </div>
      <p class="hero-sub">
        <Fragment set:html={t.hero_sub} />
      </p>
      <p class="hero-sub hero-kicker">
        {t.hero_kicker}
      </p>
      <a href="#what" class="scroll-cue" aria-label="Read more">&#8595;</a>
    </section>

    <!-- What's happening -->
    <section id="what">
      <h2>{t.what_heading}</h2>
      <p>
        <Fragment set:html={t.what_intro} />
      </p>
      <p>{t.what_registration}</p>
      <ul>
        <li class="li-list li-money">{t.what_req_fee}</li>
        <li class="li-list li-terms">{t.what_req_terms}</li>
        <li class="li-list li-id">{t.what_req_id}</li>
        <li class="li-list li-signing">{t.what_req_signing}</li>
        <li class="li-list li-appids">{t.what_req_appids}</li>
      </ul>
      <p class="pull-quote">
        {t.what_pullquote}
      </p>
    </section>

    <!-- Who gets hurt -->
    <section id="impact">
      <h2>{t.impact_heading}</h2>

      <div class="impact-cards">
        <div class="impact-card impact-consumer">
          <h3>{t.impact_you_heading}</h3>
          <p>{t.impact_you_p1}</p>
          <p><Fragment set:html={t.impact_you_p2} /></p>
        </div>

        <div class="impact-card impact-dev">
          <h3>{t.impact_dev_heading}</h3>
          <p>{t.impact_dev_p1}</p>
          <p><Fragment set:html={t.impact_dev_p2} /></p>
        </div>

        <div class="impact-card impact-gov">
          <h3>{t.impact_gov_heading}</h3>
          <p><Fragment set:html={t.impact_gov_p1} /></p>
          <p><Fragment set:html={t.impact_gov_p2} /></p>
        </div>
      </div>
    </section>

    <!-- The "solution" that isn't -->
    <section id="advanced-flow">
      <div class="callout-warning callout-trapdoor">
        <h3><Fragment set:html={t.flow_heading} /></h3>
        <p><Fragment set:html={t.flow_intro} /></p>
        <ol class="scare-steps">
          <li><Fragment set:html={t.flow_step1} /></li>
          <li><Fragment set:html={t.flow_step2} /></li>
          <li><Fragment set:html={t.flow_step3} /></li>
          <li><Fragment set:html={t.flow_step4} /></li>
          <li><Fragment set:html={t.flow_step5} /></li>
          <li class="step-highlight"><Fragment set:html={t.flow_step6} /></li>
          <li><Fragment set:html={t.flow_step7} /></li>
          <li><Fragment set:html={t.flow_step8} /></li>
          <li><Fragment set:html={t.flow_step9} /></li>
        </ol>
        <p><Fragment set:html={t.flow_summary} /></p>
        <p><Fragment set:html={t.flow_detail} /></p>
      </div>
    </section>

    <!-- Why you should care -->
    <section id="precedent" class="precedent-section">
      <h2>{t.precedent_heading}</h2>

      <p class="pull-quote">
        {t.precedent_pullquote}
      </p>

      <p><Fragment set:html={t.precedent_p1} /></p>
      <p><Fragment set:html={t.precedent_p2} /></p>
      <p><Fragment set:html={t.precedent_arstechnica} /></p>
    </section>

    <!-- Objections addressed -->
    <section id="objections" class="objections-section">
      <h2>{t.objections_heading}</h2>

      <details open>
        <summary><h4><Fragment set:html={t.obj_security_q} /></h4></summary>
        <p><Fragment set:html={t.obj_security_a} /></p>
      </details>

      <details open>
        <summary><h4><Fragment set:html={t.obj_sideloading_q} /></h4></summary>
        <p><Fragment set:html={t.obj_sideloading_a} /></p>
      </details>

      <details open>
        <summary><h4><Fragment set:html={t.obj_hide_q} /></h4></summary>
        <p><Fragment set:html={t.obj_hide_a} /></p>
      </details>

      <details open>
        <summary><h4><Fragment set:html={t.obj_apple_q} /></h4></summary>
        <p><Fragment set:html={t.obj_apple_a} /></p>
      </details>

      <details open>
        <summary><h4><Fragment set:html={t.obj_cost_q} /></h4></summary>
        <p><Fragment set:html={t.obj_cost_a} /></p>
      </details>
    </section>

    <!-- What you can do -->
    <section id="act" class="action-section">
      <h2 id="help">{t.act_heading}</h2>

      <div class="action-block">
        <h3 id="everyone">{t.act_everyone_heading}</h3>
        <ul>
          <li><Fragment set:html={t.act_fdroid} /></li>
          <li><Fragment set:html={t.act_regulators} /></li>
          <li><Fragment set:html={t.act_share} /></li>
          <li><Fragment set:html={t.act_astroturf} /></li>
          <li><Fragment set:html={t.act_petition} /></li>
          <li><Fragment set:html={t.act_letter} /></li>
          <li><Fragment set:html={t.act_survey} /></li>
        </ul>
      </div>

      <div class="action-block action-dev-block">
        <h3 id="developers">{t.act_dev_heading}</h3>
        <p><Fragment set:html={t.act_dev_intro} /></p>
        <p class="callout-resist">{t.act_dev_resist}</p>
        <ul>
          <li>{t.act_dev_talk}</li>
          <li><Fragment set:html={t.act_dev_warn} /></li>
          <li><Fragment set:html={t.act_dev_banner} /></li>
        </ul>
      </div>

      <div class="action-block">
        <h3>{t.act_google_heading}</h3>
        <p><Fragment set:html={t.act_google_text} /></p>
      </div>
    </section>

    <!-- Signatories -->
    <section id="signatories" class="signatories-landing">
      <div class="sig-rule"></div>
      <h2>All those opposed&hellip;</h2>
      <p class="sig-count">{signatures.length} organizations from {sigCountryCount} countries have signed the <a href="/open-letter">open letter</a></p>
      <QuoteTicker direction="right" variant="sigs" duration={160}>
        {shuffledSigs.map((sig: any) => (
          <a href={`https://${sig.url}`} target="_blank" class="ticker-card tc-sig">
            <img class="sig-card-logo" src={logoPath(sig.url)} alt="" loading="lazy" />
            <span class="sig-card-name">{sig.organization}</span>
            <span class="sig-card-url">{sig.url}</span>
          </a>
        ))}
      </QuoteTicker>
      <p style="text-align:center; margin-top: 1rem;">
        <a href="/open-letter" class="more-link">Read the full open letter and thank the signatories &rarr;</a>
      </p>
    </section>

    <!-- Press and coverage -->
    <section id="voices" class="voices-section">
      <h2>{t.voices_heading}</h2>

      <h3 class="voices-category">{t.voices_press}</h3>
      <QuoteTicker direction="left" variant="press" duration={270}>
        {pressItems.map((item: any) => (
          <blockquote class="ticker-card" data-color={item.color || null}>
            <p>"{item.quote}"</p>
            <cite>{item.author && <>{item.author}, </>}<a href={item.url} target="_blank">{item.source} &#8599;</a></cite>
          </blockquote>
        ))}
      </QuoteTicker>

      <h3 class="voices-category">{t.voices_editorials}</h3>
      <QuoteTicker direction="right" variant="featured" duration={135}>
        {editorialItems.map((item: any) => (
          <blockquote class="ticker-card tc-featured" data-color={item.color || null}>
            <p>"{item.quote}"</p>
            <cite>{item.author && <>{item.author}, </>}<a href={item.url} target="_blank">{item.source} &#8599;</a></cite>
          </blockquote>
        ))}
      </QuoteTicker>

      <h3 class="voices-category">{t.voices_orgs}</h3>
      <QuoteTicker direction="left" variant="org" duration={120}>
        {orgItems.map((item: any) => (
          <blockquote class="ticker-card" data-color={item.color || null}>
            <p>"{item.quote}"</p>
            <cite><a href={item.url} target="_blank">{item.source} &#8599;</a></cite>
          </blockquote>
        ))}
      </QuoteTicker>

      <h3 class="voices-category">{t.voices_creators}</h3>
      <QuoteTicker direction="right" variant="video" duration={210}>
        {creatorItems.map((item: any) => (
          <blockquote class="ticker-card tc-video" data-color={item.color || null}>
            <p>"{item.quote}"</p>
            <cite>{item.author} &ndash; <a href={item.url} target="_blank">{item.link_text || 'YouTube'} &#8599;</a></cite>
          </blockquote>
        ))}
      </QuoteTicker>

      <h3 class="voices-category">{t.voices_community}</h3>
      <QuoteTicker direction="left" variant="community" duration={180}>
        {communityItems.map((item: any) => (
          <blockquote class="ticker-card tc-community" data-color={item.color || null}>
            <p>"{item.quote}"</p>
            <cite>{item.author}{item.author_note && <> ({item.author_note})</>}, <a href={item.url} target="_blank">{item.source} &#8599;</a></cite>
          </blockquote>
        ))}
      </QuoteTicker>

      {petitionItems.length > 0 && (
        <>
          <h3 class="voices-category">{t.voices_petition}</h3>
          <QuoteTicker direction="right" variant="petition" duration={240}>
            {petitionItems.map((item: any) => (
              <blockquote class="ticker-card tc-petition">
                <p>"{item.content}"</p>
                <cite>{item.author}, <a href="https://www.change.org/p/stop-google-from-limiting-apk-file-usage/" target="_blank">change.org &#8599;</a></cite>
              </blockquote>
            ))}
          </QuoteTicker>
        </>
      )}

      <p style="text-align:center; margin-top: 2rem;">
        <a href="/cta/" class="more-link">{t.voices_more} &rarr;</a>
      </p>
    </section>

    <!-- CTA banner -->
    <section id="take-action" class="cta-banner">
      <a href="/cta/" class="cta-banner-link">
        <span class="cta-banner-label">{t.cta_action_label}</span>
        <span class="cta-banner-desc">{t.cta_action_desc}</span>
        <span class="cta-banner-arrow">&rarr;</span>
      </a>
      <a href="/open-letter" class="cta-banner-link cta-banner-link-alt">
        <span class="cta-banner-label">{t.cta_letter_label}</span>
        <span class="cta-banner-desc">{t.cta_letter_desc}</span>
        <span class="cta-banner-arrow">&rarr;</span>
      </a>
    </section>

    <!-- Closing -->
    <section id="share" class="closing">
      <p class="closing-lede">
        {t.closing_line1}<br>
        {t.closing_line2}
      </p>
      <p>
        {t.closing_detail}
      </p>
      <p class="closing-cta">
        <strong>{t.closing_cta}</strong>
      </p>
    </section>
  </main>

  <footer class="landing-footer">
    <div class="landing-footer-inner">
      <div class="footer-brand">
        <a href="/" class="outerlync">
          <img class="innerlync" alt="Altered Deal Logo" src="/img/altered-deal.png" style="width: 150px;">
        </a>
        <h2 class="footer-title">{t.title}</h2>
        <div class="footer-social">
          <a href="https://techhub.social/@keepandroidopen" aria-label="Mastodon" title="Mastodon" rel="me" target="_blank"><span class="social-icon icon-mastodon" style="width:24px;height:24px"></span></a>
          <a href="https://bsky.app/profile/keepandroidopen.bsky.social" aria-label="BlueSky" title="BlueSky" target="_blank"><span class="social-icon icon-bluesky" style="width:24px;height:24px"></span></a>
          <a href="https://x.com/AlteredDeal" aria-label="Twitter" title="Twitter" target="_blank"><span class="social-icon icon-x" style="width:24px;height:24px"></span></a>
          <a href="https://linkedin.com/company/keepandroidopen" aria-label="LinkedIn" title="LinkedIn" target="_blank"><span class="social-icon icon-linkedin" style="width:24px;height:24px"></span></a>
        </div>
      </div>
      <div class="footer-links-row">
        <div class="footer-col">
          <h4>{t.footer_get_involved}</h4>
          <ul>
            <li><a href="/cta/">{t.footer_take_action}</a></li>
            <li><a href="/open-letter">{t.footer_open_letter}</a></li>
            <li><a href="/banner">{t.footer_add_banner}</a></li>
            <li><a href="https://www.change.org/p/stop-google-from-limiting-apk-file-usage/" target="_blank">{t.footer_sign_petition} &#8599;</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>{t.footer_contact}</h4>
          <ul>
            <li><a href="mailto:info@keepandroidopen.org">info@keepandroidopen.org</a></li>
            <li><a href="mailto:tips@keepandroidopen.org">tips@keepandroidopen.org</a></li>
            <li><a href="https://github.com/keepandroidopen/keepandroidopen.github.io/issues" target="_blank">{t.footer_report_issues} &#8599;</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>{t.footer_translations}</h4>
          <ul>
            <li><a href="/cta/">{t.footer_languages}</a></li>
            <li><a href={translateUrl} target="_blank">{t.footer_help_translate}{translatePct < 100 && ` (${translatePct}%)`} &#8599;</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-legal">
        <p><Fragment set:html={markdownify(t.site_disclaimer)} /></p>
        <p><Fragment set:html={markdownify(t.site_privacy)} /></p>
        <p>
          <Fragment set:html={markdownify(t.site_copyright)} /> <a href="https://creativecommons.org/publicdomain/zero/1.0/">CC0 1.0 Universal</a><img src="/img/cc.svg" alt="CC0" style="max-width: 1em; max-height: 1em; margin-left: .2em;"><img src="/img/zero.svg" alt="Zero" style="max-width: 1em; max-height: 1em; margin-left: .2em;">
        </p>
      </div>
    </div>
  </footer>

</Base>
